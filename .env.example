# Leave unset in local dev to use the Vite proxy configured in vite.config.ts
# (forwards /api/* to http://localhost:8080, avoiding CORS since the backend
# doesn't have CORS configured yet — see docs/FRONTEND_INTEGRATION.md).
# Set this when the frontend isn't proxied to the backend (e.g. staging/prod).
# VITE_API_BASE_URL=http://localhost:8080

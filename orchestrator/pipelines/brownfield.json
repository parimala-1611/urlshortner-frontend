{
  "name": "brownfield-cors",
  "description": "Brownfield scenario: add configurable CORS support to the existing backend.",
  "stages": [
    {
      "name": "requirements",
      "runner": "orchestrator.stages.requirements.run",
      "params": {
        "artifact": "orchestrator/artifacts/brownfield/requirements.md",
        "ambiguous": false
      }
    },
    {
      "name": "design",
      "runner": "orchestrator.stages.design.run",
      "depends_on": ["requirements"],
      "params": {"artifact": "orchestrator/artifacts/brownfield/design.md"}
    },
    {
      "name": "implementation",
      "runner": "orchestrator.stages.implementation.run",
      "depends_on": ["design"],
      "rollback_on_failure": true,
      "params": {
        "expected_paths": [
          "src/main/java/com/urlshortener/config/CorsConfig.java",
          "src/main/resources/application.yml"
        ]
      }
    },
    {
      "name": "test",
      "runner": "orchestrator.stages.test.run",
      "depends_on": ["implementation"],
      "max_retries": 1,
      "rollback_on_failure": true,
      "params": {"test_filter": "CorsConfigTest,CorsConfigDefaultTest"}
    },
    {
      "name": "docs",
      "runner": "orchestrator.stages.docs.run",
      "depends_on": ["implementation"],
      "max_retries": 1,
      "params": {
        "expected_docs": ["docs/BACKEND.md", "docs/FRONTEND_INTEGRATION.md"]
      }
    },
    {
      "name": "compliance",
      "runner": "orchestrator.stages.compliance.run",
      "depends_on": ["test", "docs"],
      "params": {"max_files": 30}
    },
    {
      "name": "release_readiness",
      "runner": "orchestrator.stages.release_readiness.run",
      "depends_on": ["compliance"],
      "requires_approval": true,
      "params": {"manifest_path": "orchestrator/artifacts/brownfield/release_manifest.json"}
    }
  ]
}

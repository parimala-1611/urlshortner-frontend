{
  "name": "greenfield-qr-code",
  "description": "Greenfield scenario: add QR code generation for short URLs.",
  "stages": [
    {
      "name": "requirements",
      "runner": "orchestrator.stages.requirements.run",
      "params": {
        "artifact": "orchestrator/artifacts/greenfield/requirements.md",
        "ambiguous": false
      }
    },
    {
      "name": "design",
      "runner": "orchestrator.stages.design.run",
      "depends_on": ["requirements"],
      "params": {"artifact": "orchestrator/artifacts/greenfield/design.md"}
    },
    {
      "name": "implementation",
      "runner": "orchestrator.stages.implementation.run",
      "depends_on": ["design"],
      "rollback_on_failure": true,
      "params": {
        "expected_paths": [
          "src/main/java/com/urlshortener/service/QrCodeService.java",
          "src/main/java/com/urlshortener/web/ShortUrlController.java",
          "pom.xml"
        ]
      }
    },
    {
      "name": "test",
      "runner": "orchestrator.stages.test.run",
      "depends_on": ["implementation"],
      "max_retries": 1,
      "rollback_on_failure": true,
      "params": {"test_filter": "QrCodeServiceTest,ShortUrlControllerTest"}
    },
    {
      "name": "docs",
      "runner": "orchestrator.stages.docs.run",
      "depends_on": ["implementation"],
      "max_retries": 1,
      "params": {
        "expected_docs": ["docs/BACKEND.md", "docs/schemas.md", "openapi.yml"]
      }
    },
    {
      "name": "compliance",
      "runner": "orchestrator.stages.compliance.run",
      "depends_on": ["test", "docs"],
      "params": {
        "max_files": 30,
        "protected_files": [".github/workflows/"],
        "_note": "pom.xml excluded from protected_files for this pipeline only: adding the ZXing dependency was an explicit, already-approved decision recorded in design.md. Other pipelines (brownfield/ambiguous) keep the default protection."
      }
    },
    {
      "name": "release_readiness",
      "runner": "orchestrator.stages.release_readiness.run",
      "depends_on": ["compliance"],
      "requires_approval": true,
      "params": {"manifest_path": "orchestrator/artifacts/greenfield/release_manifest.json"}
    }
  ]
}
